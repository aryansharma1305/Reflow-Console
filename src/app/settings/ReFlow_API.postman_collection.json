{
  "info": {
    "_postman_id": "reflow-backend-api-v1",
    "name": "ReFlow Backend API",
    "description": "Complete API documentation for the ReFlow IoT Backend.\n\n**Base URL:** `{{baseUrl}}`\n\n**Authentication:** Most endpoints require a Bearer JWT token in the `Authorization` header. Obtain a token via the Login or Verify OTP endpoints.\n\n**Response Format:** All responses follow `{ message, status, data? }`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "projectId",
      "value": "",
      "type": "string"
    },
    {
      "key": "deviceId",
      "value": "",
      "type": "string"
    },
    {
      "key": "memberId",
      "value": "",
      "type": "string"
    },
    {
      "key": "sessionId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "description": "System health and status checks.",
      "item": [
        {
          "name": "Root - Welcome",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Returns API welcome message, version, and timestamp. No authentication required."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Welcome to Reflow Technologies API\",\n  \"status\": \"success\",\n  \"version\": \"1.0.0\",\n  \"iss\": \"Reflow Technologies\",\n  \"timestamp\": \"2026-03-25T00:00:00.000Z\"\n}"
            }
          ]
        },
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            },
            "description": "Checks API and database health status. No authentication required."
          },
          "response": [
            {
              "name": "Healthy",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"Health check successful\",\n  \"database\": { \"status\": \"ok\", \"message\": \"Database connection is healthy\" },\n  \"version\": \"1.0.0\",\n  \"iss\": \"Reflow Technologies\",\n  \"timestamp\": \"2026-03-25T00:00:00.000Z\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "description": "User authentication endpoints — signup, login, OTP generation, and verification. No authentication required.",
      "item": [
        {
          "name": "Signup",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"name\": \"John Doe\",\n  \"password\": \"securePassword123\",\n  \"contactNumber\": \"+919876543210\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/user/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "user", "signup"]
            },
            "description": "Register a new user. A 6-digit verification code is emailed (expires in 15 minutes).\n\n**Required fields:** `email`, `name`, `password`, `contactNumber`\n\n**Validations:**\n- Valid personal email format\n- Valid contact number format\n- Email must not already be registered"
          },
          "response": [
            {
              "name": "Success (201)",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"User registered successfully. Verification email sent.\",\n  \"status\": \"success\"\n}"
            },
            {
              "name": "User Exists (409)",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"message\": \"User already exists\",\n  \"status\": \"error\"\n}"
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"securePassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/user/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "user", "login"]
            },
            "description": "Login with email and password. Returns a JWT token.\n\n**Required fields:** `email`, `password`\n\n**Pre-conditions:** User must be verified."
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"User logged in successfully\",\n  \"status\": \"success\",\n  \"data\": {\n    \"token\": \"eyJhbGciOiJIUzI1NiIs...\"\n  }\n}"
            },
            {
              "name": "Not Verified (403)",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"message\": \"User not verified\",\n  \"status\": \"error\"\n}"
            }
          ]
        },
        {
          "name": "Generate OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"action\": \"login\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/user/generate/otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "user", "generate", "otp"]
            },
            "description": "Generate and send a 6-digit OTP to the user's email (expires in 10 minutes).\n\n**Required fields:** `email`, `action`\n\n**`action` values:**\n- `\"login\"` — OTP for login (user must be verified)\n- `\"signup\"` — OTP for account verification"
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"OTP sent successfully to your email\",\n  \"status\": \"success\"\n}"
            }
          ]
        },
        {
          "name": "Verify OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"verificationCode\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/user/verify/otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "user", "verify", "otp"]
            },
            "description": "Verify an OTP code. On success, marks the user as verified and returns a JWT token.\n\n**Required fields:** `email`, `verificationCode`"
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"User verified successfully\",\n  \"status\": \"success\",\n  \"data\": {\n    \"token\": \"eyJhbGciOiJIUzI1NiIs...\"\n  }\n}"
            },
            {
              "name": "Expired (400)",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"message\": \"Verification code has expired.\",\n  \"status\": \"error\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Profile",
      "description": "User profile management. All routes require authentication.",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "profile"]
            },
            "description": "Retrieve the authenticated user's profile including organization info and role."
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Profile retrieved successfully\",\n  \"status\": \"success\",\n  \"data\": {\n    \"profile\": {\n      \"email\": \"user@example.com\",\n      \"name\": \"John Doe\",\n      \"contactNumber\": \"+919876543210\",\n      \"verified\": true,\n      \"organization\": {\n        \"id\": \"org_id\",\n        \"name\": \"My Org\",\n        \"role\": \"OWNER\"\n      }\n    }\n  }\n}"
            }
          ]
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Updated\",\n  \"contactNumber\": \"+919876543211\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "profile"]
            },
            "description": "Update the authenticated user's profile.\n\n**Optional fields (at least one required):** `name`, `contactNumber`"
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Profile updated successfully\",\n  \"status\": \"success\",\n  \"data\": {\n    \"profile\": {\n      \"id\": \"user_id\",\n      \"email\": \"user@example.com\",\n      \"name\": \"John Updated\",\n      \"contactNumber\": \"+919876543211\",\n      \"verified\": true\n    }\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Organization",
      "description": "Organization management — CRUD, membership, roles, ownership transfer, and activity log. All routes require authentication.",
      "item": [
        {
          "name": "Create Organization",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Organization\",\n  \"description\": \"IoT monitoring company\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/organization",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "organization"]
            },
            "description": "Create a new organization. The authenticated user becomes the OWNER.\n\n**Required:** `name`\n**Optional:** `description`\n\n**Constraints:** User must not already own or be a member of an organization."
          },
          "response": [
            {
              "name": "Success (201)",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"Organization created successfully\",\n  \"status\": \"success\",\n  \"data\": {\n    \"organization\": {\n      \"id\": \"org_id\",\n      \"name\": \"My Organization\",\n      \"description\": \"IoT monitoring company\",\n      \"ownerId\": \"user_id\",\n      \"owner\": { \"name\": \"John\", \"email\": \"john@example.com\" }\n    }\n  }\n}"
            }
          ]
        },
        {
          "name": "Get Organization",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/organization",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "organization"]
            },
            "description": "Get the authenticated user's organization with members and projects."
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Organization retrieved successfully\",\n  \"status\": \"success\",\n  \"data\": {\n    \"organization\": {\n      \"id\": \"org_id\",\n      \"name\": \"My Organization\",\n      \"members\": [],\n      \"projects\": []\n    }\n  }\n}"
            }
          ]
        },
        {
          "name": "Invite User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"role\": \"MEMBER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/organization/invite",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "organization", "invite"]
            },
            "description": "Invite a user to the organization. \n\n**If user is registered:** Adds them directly and sends a notification email.\n**If user is NOT registered:** Sends an invitation email with a Register button.\n\n**Required:** `email`\n**Optional:** `role` (default: `MEMBER`)\n\n**Role values:** `ADMIN`, `MEMBER` (cannot assign `OWNER`)\n\n**Permissions:**\n- OWNER can assign ADMIN or MEMBER\n- ADMIN can only assign MEMBER"
          },
          "response": [
            {
              "name": "Registered User Invited (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"User invited successfully\",\n  \"status\": \"success\"\n}"
            },
            {
              "name": "Unregistered User - Email Sent (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"User is not registered. Invitation email sent to register.\",\n  \"status\": \"success\"\n}"
            }
          ]
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/organization/member/{{memberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "organization", "member", "{{memberId}}"]
            },
            "description": "Remove a member from the organization.\n\n**Path param:** `memberId` — the user ID to remove\n\n**Permissions:**\n- OWNER can remove anyone except themselves\n- ADMIN can only remove MEMBERs\n- Cannot remove the OWNER"
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"User removed successfully\",\n  \"status\": \"success\"\n}"
            }
          ]
        },
        {
          "name": "Update Member Role",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/organization/member/{{memberId}}/role",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "organization", "member", "{{memberId}}", "role"]
            },
            "description": "Change a member's role within the organization.\n\n**Path param:** `memberId`\n**Required:** `role` (`ADMIN` or `MEMBER`)\n\n**Permissions:** Only the OWNER can change roles. Use transfer-ownership for OWNER role."
          },
          "response": [
            {
              "name": "Promoted (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"User promoted to ADMIN successfully\",\n  \"status\": \"success\"\n}"
            }
          ]
        },
        {
          "name": "Get Members",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/organization/members",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "organization", "members"]
            },
            "description": "Get all members of the organization with their roles.\n\n**Permissions:** Only the OWNER can view the full members list."
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Organization members retrieved successfully\",\n  \"status\": \"success\",\n  \"data\": {\n    \"members\": [\n      {\n        \"id\": \"user_id\",\n        \"name\": \"John\",\n        \"email\": \"john@example.com\",\n        \"role\": \"OWNER\",\n        \"joinedAt\": \"2026-01-01T00:00:00.000Z\"\n      }\n    ]\n  }\n}"
            }
          ]
        },
        {
          "name": "Leave Organization",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/organization/leave",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "organization", "leave"]
            },
            "description": "Leave the organization. OWNERs must transfer ownership first."
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Left organization successfully\",\n  \"status\": \"success\"\n}"
            }
          ]
        },
        {
          "name": "Transfer Ownership",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newOwnerId\": \"target_user_id\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/organization/transfer-ownership",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "organization", "transfer-ownership"]
            },
            "description": "Transfer organization ownership to another member. The current OWNER is demoted to ADMIN.\n\n**Required:** `newOwnerId` — must be an existing organization member.\n\n**Permissions:** Only the current OWNER can transfer ownership."
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Ownership transferred successfully\",\n  \"status\": \"success\"\n}"
            }
          ]
        },
        {
          "name": "Get Activities",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/organization/activities",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "organization", "activities"]
            },
            "description": "Get the last 50 activity log entries for the organization."
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Organization activities retrieved successfully\",\n  \"status\": \"success\",\n  \"data\": {\n    \"activities\": [\n      {\n        \"id\": \"act_id\",\n        \"action\": \"USER_INVITED\",\n        \"userId\": \"user_id\",\n        \"description\": \"John invited Jane to join the organization\",\n        \"createdAt\": \"2026-03-25T00:00:00.000Z\"\n      }\n    ]\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Projects",
      "description": "Project management — create, list, share, and delete projects. All routes require authentication.",
      "item": [
        {
          "name": "Get Projects",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/projects",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "projects"]
            },
            "description": "List all projects the user has access to.\n\n**Access levels:**\n- OWNER / ADMIN: See all organization projects\n- MEMBER: See only own projects + shared projects\n\nEach project includes an `accessLevel` field."
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Projects retrieved successfully\",\n  \"status\": \"success\",\n  \"data\": {\n    \"projects\": [\n      {\n        \"id\": \"proj_id\",\n        \"name\": \"My Project\",\n        \"description\": \"...\",\n        \"accessLevel\": \"owner\",\n        \"createdBy\": { \"id\": \"...\", \"name\": \"...\", \"email\": \"...\" },\n        \"organization\": { \"id\": \"...\", \"name\": \"...\" }\n      }\n    ]\n  }\n}"
            }
          ]
        },
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Project\",\n  \"description\": \"Project description\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/project",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "project"]
            },
            "description": "Create a new project within the user's organization.\n\n**Required:** `name`\n**Optional:** `description`\n\nNon-owner creators automatically get EDITOR access via ProjectShare."
          },
          "response": [
            {
              "name": "Success (201)",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"Project created successfully\",\n  \"status\": \"success\",\n  \"data\": {\n    \"project\": {\n      \"id\": \"proj_id\",\n      \"name\": \"New Project\",\n      \"description\": \"Project description\"\n    }\n  }\n}"
            }
          ]
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/project/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "project", "{{projectId}}"]
            },
            "description": "Delete a project and all related data (cascading).\n\n**Path param:** `projectId`\n\n**Permissions:** OWNER, ADMIN, or the project creator."
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Project deleted successfully\",\n  \"status\": \"success\"\n}"
            }
          ]
        },
        {
          "name": "Share Project",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userEmail\": \"member@example.com\",\n  \"role\": \"VIEWER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/project/{{projectId}}/share",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "project", "{{projectId}}", "share"]
            },
            "description": "Share a project with another organization member.\n\n**Path param:** `projectId`\n**Required:** `userEmail`\n**Optional:** `role` (default: `VIEWER`). Values: `VIEWER`, `EDITOR`\n\n**Permissions:** OWNER, ADMIN, or the project creator.\n**Constraint:** Target user must be in the same organization."
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Project shared successfully\",\n  \"status\": \"success\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Devices",
      "description": "Device management — CRUD, move between projects, data export, and MQTT config. All routes require authentication.",
      "item": [
        {
          "name": "Get Project Devices",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/project/{{projectId}}/devices",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "project", "{{projectId}}", "devices"]
            },
            "description": "List all devices in a project.\n\n**Path param:** `projectId`\n\nResponse includes `accessLevel` and `canEdit` flags."
          },
          "response": [
            {
              "name": "Success (200)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Devices retrieved successfully\",\n  \"status\": \"success\",\n  \"data\": {\n    \"devices\": [],\n    \"accessLevel\": \"owner\",\n    \"canEdit\": true\n  }\n}"
            }
          ]
        },
        {
          "name": "Create Device",
          "request": {
            "method": "POST",
            "header": [
